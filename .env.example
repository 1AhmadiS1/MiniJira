# Development values. Copy to .env; never commit the real .env file.
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-development-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

DB_NAME=minijira
DB_USER=postgres
DB_PASSWORD=replace-with-a-local-password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_SSLMODE=prefer

# Docker Compose overrides the hosts to the Docker service names.
REDIS_URL=
CACHE_TIMEOUT=300
CACHE_KEY_PREFIX=minijira-dev

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

USE_S3=False

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
TRUST_PROXY_HEADERS=False
