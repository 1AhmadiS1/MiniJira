# Copy to .env.production on the server and replace every CHANGE_ME value.
ENVIRONMENT=production
ECR_IMAGE=CHANGE_ME_ACCOUNT.dkr.ecr.eu-central-1.amazonaws.com/minijira:CHANGE_ME_TAG
SECRET_KEY=CHANGE_ME_generate_at_least_50_random_characters
DEBUG=False
ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com

DB_NAME=minijira
DB_USER=minijira
DB_PASSWORD=CHANGE_ME_use_a_long_database_password
DB_HOST=CHANGE_ME_RDS_ENDPOINT
DB_PORT=5432
DB_CONN_MAX_AGE=60
# RDS requires encrypted connections in production.
DB_SSLMODE=require

# Use the ElastiCache endpoint when eligible. Otherwise keep this value and
# launch Compose with: --profile local-redis
REDIS_URL=redis://redis:6379/1
CACHE_TIMEOUT=300
CACHE_KEY_PREFIX=minijira-prod

# Start with two workers on a small EC2 instance and tune after measuring RAM.
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Required in production so private attachments are not exposed by Nginx and
# every web replica sees the same files. Prefer an IAM role over static keys.
USE_S3=True
AWS_STORAGE_BUCKET_NAME=CHANGE_ME
AWS_S3_REGION_NAME=CHANGE_ME
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True

# Enable these only after HTTPS is configured and verified in Nginx.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
TRUST_PROXY_HEADERS=False
